{
  "name": "classschedule",
  "version": "1.0.1",
  "description": "ClassSchedule - Quan ly lich day",
  "main": "main.js",
  "author": "Hannah",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.hannah.classschedule",
    "productName": "ClassSchedule",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      {
        "from": "..",
        "to": "..",
        "filter": [
          "index.html",
          "style.css",
          "css/**/*",
          "js/**/*",
          "favicon.svg"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "shortcutName": "ClassSchedule"
    }
  }
}
