{
  "name": "classschedule",
  "version": "1.0.2",
  "description": "ClassSchedule - Quan ly lich day",
  "main": "main.js",
  "author": "Hannah",
  "license": "MIT",
  "scripts": {
    "prebuild:win": "node copy-app.js",
    "build:win": "electron-builder --win --x64",
    "prebuild:portable": "node copy-app.js",
    "build:portable": "electron-builder --win portable",
    "start": "electron ."
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.hannah.classschedule",
    "productName": "ClassSchedule",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "app/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "shortcutName": "ClassSchedule"
    }
  }
}
